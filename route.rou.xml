<routes>
    <!--
        Vietnam traffic profile:
        - Motorbikes are the dominant vehicle (~75-80% of all vehicles)
        - Cars account for ~15-20%
        - Drivers have short following distances, low lane discipline (high sigma),
          and aggressive behavior (high impatience, low tau)
    -->

    <!-- Motorbike: dominant vehicle in Vietnamese cities -->
    <vType id="motorbike"
           accel="2.5" decel="4.5" length="2.0" width="0.8"
           maxSpeed="13.9"
           sigma="0.8"
           tau="0.5"
           minGap="0.5"
           impatience="0.8"
           color="255,165,0"/>

    <!-- Car: less common, somewhat aggressive by Western standards -->
    <vType id="car"
           accel="2.0" decel="4.5" length="4.5" width="1.8"
           maxSpeed="13.9"
           sigma="0.5"
           tau="0.9"
           minGap="1.5"
           impatience="0.5"
           color="0,128,255"/>

    <!-- Routes: straight-through and turning movements -->
    <route id="north_south" edges="n2c c2s"/>
    <route id="north_west"  edges="n2c c2w"/>
    <route id="north_east"  edges="n2c c2e"/>
    <route id="south_north" edges="s2c c2n"/>
    <route id="south_east"  edges="s2c c2e"/>
    <route id="south_west"  edges="s2c c2w"/>
    <route id="east_west"   edges="e2c c2w"/>
    <route id="east_south"  edges="e2c c2s"/>
    <route id="east_north"  edges="e2c c2n"/>
    <route id="west_east"   edges="w2c c2e"/>
    <route id="west_south"  edges="w2c c2s"/>
    <route id="west_north"  edges="w2c c2n"/>

    <!-- ============================================================
         OFF-PEAK (0 - 1800s): light traffic
         ============================================================ -->
    <flow id="mb_ns_op"  type="motorbike" route="north_south" begin="0"    end="1800" vehsPerHour="320"/>
    <flow id="mb_nw_op"  type="motorbike" route="north_west"  begin="0"    end="1800" vehsPerHour="120"/>
    <flow id="mb_ne_op"  type="motorbike" route="north_east"  begin="0"    end="1800" vehsPerHour="80"/>
    <flow id="mb_sn_op"  type="motorbike" route="south_north" begin="0"    end="1800" vehsPerHour="320"/>
    <flow id="mb_se_op"  type="motorbike" route="south_east"  begin="0"    end="1800" vehsPerHour="120"/>
    <flow id="mb_sw_op"  type="motorbike" route="south_west"  begin="0"    end="1800" vehsPerHour="80"/>
    <flow id="mb_ew_op"  type="motorbike" route="east_west"   begin="0"    end="1800" vehsPerHour="280"/>
    <flow id="mb_es_op"  type="motorbike" route="east_south"  begin="0"    end="1800" vehsPerHour="100"/>
    <flow id="mb_en_op"  type="motorbike" route="east_north"  begin="0"    end="1800" vehsPerHour="60"/>
    <flow id="mb_we_op"  type="motorbike" route="west_east"   begin="0"    end="1800" vehsPerHour="280"/>
    <flow id="mb_ws_op"  type="motorbike" route="west_south"  begin="0"    end="1800" vehsPerHour="100"/>
    <flow id="mb_wn_op"  type="motorbike" route="west_north"  begin="0"    end="1800" vehsPerHour="60"/>

    <flow id="car_ns_op" type="car"       route="north_south" begin="0"    end="1800" vehsPerHour="60"/>
    <flow id="car_nw_op" type="car"       route="north_west"  begin="0"    end="1800" vehsPerHour="25"/>
    <flow id="car_sn_op" type="car"       route="south_north" begin="0"    end="1800" vehsPerHour="60"/>
    <flow id="car_se_op" type="car"       route="south_east"  begin="0"    end="1800" vehsPerHour="25"/>
    <flow id="car_ew_op" type="car"       route="east_west"   begin="0"    end="1800" vehsPerHour="55"/>
    <flow id="car_es_op" type="car"       route="east_south"  begin="0"    end="1800" vehsPerHour="20"/>
    <flow id="car_we_op" type="car"       route="west_east"   begin="0"    end="1800" vehsPerHour="55"/>
    <flow id="car_ws_op" type="car"       route="west_south"  begin="0"    end="1800" vehsPerHour="20"/>

    <!-- ============================================================
         MORNING RUSH HOUR (1800 - 5400s): ~2x-3x volume surge,
         northbound and eastbound (commuting into city center) heavier
         ============================================================ -->
    <flow id="mb_ns_rh"  type="motorbike" route="north_south" begin="1800" end="5400" vehsPerHour="750"/>
    <flow id="mb_nw_rh"  type="motorbike" route="north_west"  begin="1800" end="5400" vehsPerHour="280"/>
    <flow id="mb_ne_rh"  type="motorbike" route="north_east"  begin="1800" end="5400" vehsPerHour="180"/>
    <flow id="mb_sn_rh"  type="motorbike" route="south_north" begin="1800" end="5400" vehsPerHour="600"/>
    <flow id="mb_se_rh"  type="motorbike" route="south_east"  begin="1800" end="5400" vehsPerHour="220"/>
    <flow id="mb_sw_rh"  type="motorbike" route="south_west"  begin="1800" end="5400" vehsPerHour="150"/>
    <flow id="mb_ew_rh"  type="motorbike" route="east_west"   begin="1800" end="5400" vehsPerHour="680"/>
    <flow id="mb_es_rh"  type="motorbike" route="east_south"  begin="1800" end="5400" vehsPerHour="250"/>
    <flow id="mb_en_rh"  type="motorbike" route="east_north"  begin="1800" end="5400" vehsPerHour="160"/>
    <flow id="mb_we_rh"  type="motorbike" route="west_east"   begin="1800" end="5400" vehsPerHour="550"/>
    <flow id="mb_ws_rh"  type="motorbike" route="west_south"  begin="1800" end="5400" vehsPerHour="200"/>
    <flow id="mb_wn_rh"  type="motorbike" route="west_north"  begin="1800" end="5400" vehsPerHour="130"/>

    <flow id="car_ns_rh" type="car"       route="north_south" begin="1800" end="5400" vehsPerHour="160"/>
    <flow id="car_nw_rh" type="car"       route="north_west"  begin="1800" end="5400" vehsPerHour="60"/>
    <flow id="car_sn_rh" type="car"       route="south_north" begin="1800" end="5400" vehsPerHour="130"/>
    <flow id="car_se_rh" type="car"       route="south_east"  begin="1800" end="5400" vehsPerHour="50"/>
    <flow id="car_ew_rh" type="car"       route="east_west"   begin="1800" end="5400" vehsPerHour="150"/>
    <flow id="car_es_rh" type="car"       route="east_south"  begin="1800" end="5400" vehsPerHour="55"/>
    <flow id="car_we_rh" type="car"       route="west_east"   begin="1800" end="5400" vehsPerHour="120"/>
    <flow id="car_ws_rh" type="car"       route="west_south"  begin="1800" end="5400" vehsPerHour="45"/>

    <!-- ============================================================
         POST-RUSH / MIDDAY (5400 - 7200s): moderate, between peaks
         ============================================================ -->
    <flow id="mb_ns_md"  type="motorbike" route="north_south" begin="5400" end="7200" vehsPerHour="420"/>
    <flow id="mb_nw_md"  type="motorbike" route="north_west"  begin="5400" end="7200" vehsPerHour="160"/>
    <flow id="mb_sn_md"  type="motorbike" route="south_north" begin="5400" end="7200" vehsPerHour="420"/>
    <flow id="mb_se_md"  type="motorbike" route="south_east"  begin="5400" end="7200" vehsPerHour="160"/>
    <flow id="mb_ew_md"  type="motorbike" route="east_west"   begin="5400" end="7200" vehsPerHour="380"/>
    <flow id="mb_es_md"  type="motorbike" route="east_south"  begin="5400" end="7200" vehsPerHour="140"/>
    <flow id="mb_we_md"  type="motorbike" route="west_east"   begin="5400" end="7200" vehsPerHour="380"/>
    <flow id="mb_ws_md"  type="motorbike" route="west_south"  begin="5400" end="7200" vehsPerHour="140"/>

    <flow id="car_ns_md" type="car"       route="north_south" begin="5400" end="7200" vehsPerHour="80"/>
    <flow id="car_sn_md" type="car"       route="south_north" begin="5400" end="7200" vehsPerHour="80"/>
    <flow id="car_ew_md" type="car"       route="east_west"   begin="5400" end="7200" vehsPerHour="70"/>
    <flow id="car_we_md" type="car"       route="west_east"   begin="5400" end="7200" vehsPerHour="70"/>
</routes>
